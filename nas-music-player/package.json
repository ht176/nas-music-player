{
  "name": "nas-music-player",
  "version": "1.1.0",
  "type": "module",
  "description": "NAS 音乐播放器 - 轻量、快速、美观的自托管音乐播放器",
  "author": "Jarvis",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "type-check": "vue-tsc --noEmit",
    "deploy": "npm run build && npx gh-pages -d dist"
  },
  "dependencies": {
    "@vueuse/core": "^13.0.0",
    "crypto-js": "^4.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "gh-pages": "^6.3.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^2.2.0"
  }
}
